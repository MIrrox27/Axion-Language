import ai

var MODEL_TOKEN = 'api'
var MODEL_URL = 'model'
var MODEL_NAME = 'model_name'


var model = ai.set_model(MODEL_NAME, 0.5, 400)
print("Модель создана", model)


var client = ai.set_client(MODEL_TOKEN, MODEL_URL, None)
print("Клиент создан", client)


for (var i = 0; i < 10; i++){
    var msg = input(" --- Вы: ")

    var answer = ai.send_msg(msg, client, model)
    print(" --- Нейросеть:", answer)


}
