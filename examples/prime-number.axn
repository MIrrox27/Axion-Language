
    # Пример кода для определения простое ли число или нет

var num = int(input("Введите число от 1 до 1000: "))
var is_prime = False
print(is_prime)


for (var i = num - 1; i > 0; --i){



    if (num % i == 0) {
        is_prime = True;
    }

}


if not is_prime{
    print("Число", num, "- простое")
}
elif is_prime{
    print("Число", num, "- не простое")
}











